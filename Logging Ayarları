import logging
import yaml

def setup_logging(config_path="config/config.yaml"):
    with open(config_path, 'r') as f:
        config = yaml.safe_load(f)
    log_cfg = config['logging']
    logging.basicConfig(
        level=getattr(logging, log_cfg['level']),
        filename=log_cfg['file'],
        format=log_cfg['format'],
        filemode='a'
    )
    return logging.getLogger("ETLPipeline")
